# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Which model triages the mail. Default is Haiku 4.5 (cheap/fast, fine for sorting).
# Triage is a high-volume, simple classification task — this is a real cost lever:
#   claude-haiku-4-5   $1 / $5  per million tokens (in/out)  — default, fast/cheap
#   claude-sonnet-4-6  $3 / $15 per million tokens          — stronger, mid cost
#   claude-opus-4-8    $5 / $25 per million tokens          — best quality, priciest
# To switch, change the value below and restart. Leave unset to use the default.
TRIAGE_MODEL=claude-haiku-4-5

# Short label for whose inbox this is. Drives the DB filename (data/triage_<EXEC_ID>.db).
# One value per executive — this is what keeps data from commingling.
EXEC_ID=test

# Encryption key for email bodies at rest. Generate one per exec with:
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=

# How many overnight unread messages to pull per run (keeps demos fast).
MAX_MESSAGES=25

# Flask session secret (any random string).
FLASK_SECRET=change-me
