# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Which model triages the mail. Default is Opus 4.8 (highest quality).
# Cost decision for you: triage is a high-volume, simple classification task.
#   claude-opus-4-8    $5 / $25 per million tokens (in/out)  — default, best quality
#   claude-sonnet-4-6  $3 / $15 per million tokens          — strong, cheaper
#   claude-haiku-4-5   $1 / $5  per million tokens          — fast/cheap, fine for sorting
# To switch, set TRIAGE_MODEL below. Leave unset to use the default.
TRIAGE_MODEL=claude-opus-4-8

# Short label for whose inbox this is. Drives the DB filename (data/triage_<EXEC_ID>.db).
# One value per executive — this is what keeps data from commingling.
EXEC_ID=test

# Encryption key for email bodies at rest. Generate one per exec with:
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=

# How many overnight unread messages to pull per run (keeps demos fast).
MAX_MESSAGES=25

# Flask session secret (any random string).
FLASK_SECRET=change-me
